{
  "name": "uit-go",
  "version": "1.0.0",
  "description": "Cloud-native ride-sharing platform with NestJS microservices",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "dev": "nx run-many --target=serve --all --parallel",
    "start": "nx run-many --target=serve --all",
    "prisma:generate": "nx run-many --target=prisma:generate --all",
    "prisma:migrate": "nx run-many --target=prisma:migrate --all",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "monitoring:up": "docker-compose -f docker/monitoring/docker-compose.monitoring.yml up -d",
    "monitoring:down": "docker-compose -f docker/monitoring/docker-compose.monitoring.yml down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dieuxuanhien/uit-go.git"
  },
  "keywords": [
    "microservices",
    "nestjs",
    "nx",
    "ride-sharing",
    "cloud-native",
    "typescript"
  ],
  "author": "UIT-Go Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dieuxuanhien/uit-go/issues"
  },
  "homepage": "https://github.com/dieuxuanhien/uit-go#readme",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.0.0",
    "@nrwl/nest": "^19.8.4",
    "@nrwl/node": "^19.8.4",
    "@nrwl/react": "^19.8.4",
    "@nrwl/web": "^19.8.4",
    "@nrwl/workspace": "^19.8.4",
    "@nx/eslint": "19.8.4",
    "@nx/eslint-plugin": "^19.8.4",
    "@nx/jest": "^19.8.4",
    "@nx/js": "21.5.3",
    "@nx/nest": "^21.5.3",
    "@nx/node": "21.5.3",
    "@nx/web": "21.5.3",
    "@nx/webpack": "21.5.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.5.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-util": "^29.7.0",
    "nx": "21.5.3",
    "prettier": "^2.6.2",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "webpack-cli": "^5.1.4"
  },
  "nx": {},
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/websockets": "^11.1.6",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
